# ───────────────────────────────────────────────────────────────────────────
#  Forge Local Lead Scraper — environment config
#
#  Copy this file to ".env" and fill in YOUR values.
#  (The setup script does the copy for you — you just fill in the blanks.)
#
#  Lines starting with # are notes and are ignored.
# ───────────────────────────────────────────────────────────────────────────

# REQUIRED — Your Google Places API key (from your own Google Cloud project).
#   Get this in Part 3 of the setup guide. Paste it right after the = sign,
#   no quotes, no spaces. Example:  GOOGLE_MAPS_API_KEY=AIzaSyXXXXXXXXXXXXXXXX
GOOGLE_MAPS_API_KEY=

# REQUIRED — The email address your daily lead report gets sent to.
#   Use your own work email. Example:  REPORT_EMAIL=neema@forgelocal.app
REPORT_EMAIL=

# REQUIRED — Path to your downloaded Google OAuth client file.
#   Leave this exactly as-is. You just drop the downloaded file into the
#   credentials/ folder and name it oauth-client.json (Part 3 of the guide).
GOOGLE_OAUTH_CLIENT=credentials/oauth-client.json

# REQUIRED — Where your Google login token is saved.
#   Leave this exactly as-is. The file is created automatically the first time
#   you sign in — you do not create it yourself.
GOOGLE_OAUTH_TOKEN=credentials/oauth-token.json

# OPTIONAL — A specific Google Drive folder to save the lead sheets into.
#   Leave BLANK to save sheets to the top level of your Google Drive ("My Drive").
#   (To use a folder: open it in Google Drive and copy the long ID from the URL.)
GOOGLE_DRIVE_FOLDER_ID=
